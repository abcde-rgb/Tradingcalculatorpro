# ============================================================
# TradingCalculator.pro — Frontend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Backend origin without /api. Preferred by the React app.
# Example: https://your-backend.up.railway.app
REACT_APP_BACKEND_URL=

# Backward-compatible alias. May include /api; the app normalizes it.
# Example: https://your-backend.up.railway.app/api
REACT_APP_API_URL=

# Stripe checkout uses public Payment Links configured in PricingPage.jsx.
# No Stripe secret key belongs in the frontend.

# Google OAuth Client ID (optional)
REACT_APP_GOOGLE_CLIENT_ID=

# Fix for Node 17+ OpenSSL issues
NODE_OPTIONS=--openssl-legacy-provider
