# ============================================================
# TradingCalculator.pro — Frontend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# URL of your backend API, without a trailing /api.
# For Railway: https://your-backend.up.railway.app
# For Cloud Run: https://tradingcalculator-api-xxxxx-uc.a.run.app
# For local: http://localhost:8000
REACT_APP_BACKEND_URL=http://localhost:8000

# Google OAuth Client ID (optional)
REACT_APP_GOOGLE_CLIENT_ID=

# Fix for Node 17+ OpenSSL issues
NODE_OPTIONS=--openssl-legacy-provider
