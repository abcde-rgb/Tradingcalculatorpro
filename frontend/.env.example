# ============================================================
# Trading Calculator PRO — Frontend Environment Variables
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# En producción, configura estas variables en tu plataforma de deploy.
# ============================================================

# URL del backend (sin / al final)
REACT_APP_BACKEND_URL=http://localhost:8001

# Google OAuth Client ID
# DEBE ser el mismo Client ID que en backend/.env → GOOGLE_CLIENT_ID
# IMPORTANTE: En Google Console, añade la URL del frontend como
# "Authorized JavaScript origin" (no redirect URI)
# Ej: https://unified-site-1.preview.emergentagent.com
REACT_APP_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
