# ============================================================
# TradingCalculator.pro — Frontend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# URL of your backend API
# For Railway: https://your-backend.up.railway.app/api
# For local: http://localhost:8000/api
# For emergentagent: https://unified-site-1.preview.emergentagent.com/api
REACT_APP_API_URL=https://unified-site-1.preview.emergentagent.com/api

# Google OAuth Client ID (optional)
REACT_APP_GOOGLE_CLIENT_ID=

# Fix for Node 17+ OpenSSL issues
NODE_OPTIONS=--openssl-legacy-provider
