# FIX 2 — /forex-prices con Finnhub real (fallback estático si falla)
# Busca la función get_forex_prices() y reemplázala con:
# -----------------------------------------------------------

@api_router.get("/forex-prices")
async def get_forex_prices():
    """Get forex prices from Finnhub API (fallback to static if key missing)."""
    FINNHUB_KEY = os.environ.get('FINNHUB_API_KEY', '')
    FOREX_PAIRS = [
        ("EURUSD", "OANDA:EUR_USD"),
        ("GBPUSD", "OANDA:GBP_USD"),
        ("USDJPY", "OANDA:USD_JPY"),
        ("USDCHF", "OANDA:USD_CHF"),
        ("AUDUSD", "OANDA:AUD_USD"),
        ("USDCAD", "OANDA:USD_CAD"),
        ("NZDUSD", "OANDA:NZD_USD"),
        ("EURGBP", "OANDA:EUR_GBP"),
        ("EURJPY", "OANDA:EUR_JPY"),
        ("GBPJPY", "OANDA:GBP_JPY"),
    ]
    STATIC_FALLBACK = {
        "EURUSD": {"price": 1.0856, "change": 0.12},
        "GBPUSD": {"price": 1.2734, "change": -0.08},
        "USDJPY": {"price": 149.85, "change": 0.25},
        "USDCHF": {"price": 0.8812, "change": -0.05},
        "AUDUSD": {"price": 0.6542, "change": 0.18},
        "USDCAD": {"price": 1.3564, "change": 0.03},
        "NZDUSD": {"price": 0.5987, "change": 0.22},
        "EURGBP": {"price": 0.8525, "change": 0.15},
        "EURJPY": {"price": 162.68, "change": 0.38},
        "GBPJPY": {"price": 190.78, "change": 0.17},
    }
    if not FINNHUB_KEY:
        return STATIC_FALLBACK
    result = {}
    try:
        async with httpx.AsyncClient() as client:
            for pair_label, symbol in FOREX_PAIRS:
                try:
                    r = await client.get(
                        "https://finnhub.io/api/v1/quote",
                        params={"symbol": symbol, "token": FINNHUB_KEY},
                        timeout=5.0,
                    )
                    if r.status_code == 200:
                        data = r.json()
                        price = data.get("c", 0)   # current price
                        prev  = data.get("pc", price) or price
                        change_pct = round(((price - prev) / prev) * 100, 4) if prev else 0
                        result[pair_label] = {"price": price, "change": change_pct}
                    else:
                        result[pair_label] = STATIC_FALLBACK[pair_label]
                except Exception:
                    result[pair_label] = STATIC_FALLBACK[pair_label]
    except Exception as e:
        logging.error(f"Finnhub forex fetch failed: {e}")
        return STATIC_FALLBACK
    return result

