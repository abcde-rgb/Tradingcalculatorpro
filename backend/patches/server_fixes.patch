# FIX 3 — /indices-prices con yfinance real (fallback estático)
# Busca la función get_indices_prices() y reemplázala con:
# -----------------------------------------------------------

@api_router.get("/indices-prices")
async def get_indices_prices():
    """Get indices prices from yfinance (fallback to static on error)."""
    INDICES_MAP = {
        "SPX":  "^GSPC",
        "NDX":  "^NDX",
        "DJI":  "^DJI",
        "DAX":  "^GDAXI",
        "FTSE": "^FTSE",
        "N225": "^N225",
        "HSI":  "^HSI",
    }
    STATIC_FALLBACK = {
        "SPX":  {"price": 5998.50, "change": 0.45},
        "NDX":  {"price": 21245.80, "change": 0.68},
        "DJI":  {"price": 44235.20, "change": 0.32},
        "DAX":  {"price": 19785.60, "change": 0.28},
        "FTSE": {"price": 8265.40, "change": 0.15},
        "N225": {"price": 38542.80, "change": 0.52},
        "HSI":  {"price": 19876.30, "change": -0.25},
    }
    try:
        import yfinance as yf
        result = {}
        for label, yf_sym in INDICES_MAP.items():
            try:
                ticker = yf.Ticker(yf_sym)
                hist = ticker.history(period="2d", interval="1d")
                if hist.empty or len(hist) < 2:
                    result[label] = STATIC_FALLBACK[label]
                    continue
                prev_close = float(hist["Close"].iloc[-2])
                curr_close = float(hist["Close"].iloc[-1])
                change_pct = round(((curr_close - prev_close) / prev_close) * 100, 2) if prev_close else 0
                result[label] = {"price": round(curr_close, 2), "change": change_pct}
            except Exception:
                result[label] = STATIC_FALLBACK[label]
        return result
    except Exception as e:
        logging.error(f"Indices yfinance fetch failed: {e}")
        return STATIC_FALLBACK

