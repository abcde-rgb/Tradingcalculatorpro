# ============================================================
# Trading Calculator PRO — Backend Environment Variables
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# --- Base de datos MongoDB ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_calculator_pro

# --- JWT (OBLIGATORIO en producción) ---
# 🔒 CRÍTICO: Genera un valor único y fijo con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Si no se define, el servidor genera uno nuevo en cada reinicio
# y TODAS las sesiones activas quedarán invalidadas.
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO_DE_64_CHARS

# --- Google OAuth ---
# 1. Ve a https://console.cloud.google.com/
# 2. Crea un proyecto o selecciona uno existente
# 3. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized JavaScript origins: añade la URL de tu frontend
#    Ej: https://unified-site-1.preview.emergentagent.com
# 6. Authorized redirect URIs: NO es necesario para el flujo de ID token
# 7. Copia el Client ID aquí:
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# --- Stripe (Pagos) ---
# Obtén tus claves en https://dashboard.stripe.com/apikeys
# Usa sk_test_... para pruebas, sk_live_... para producción
STRIPE_API_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ID del Webhook Signing Secret (para verificar webhooks de Stripe)
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- SendGrid (Emails de alerta) ---
# Obtén tu API key en https://app.sendgrid.com/settings/api_keys
# Sin esta clave, las alertas por email se omiten silenciosamente.
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDER_EMAIL=alerts@tradingcalculator.pro

# --- Demo User ---
DEMO_EMAIL=demo@btccalc.pro
DEMO_PASSWORD=1234

# --- AI Trade Coach (Claude / Emergent LLM) ---
# Sin esta clave, /options/ai-analyze devuelve error 503 en lugar de 500.
EMERGENT_LLM_KEY=TU_EMERGENT_LLM_KEY

# --- Finnhub (Precios reales de Forex e Índices) ---
# Plan gratuito en https://finnhub.io/register (60 llamadas/min)
# Sin esta clave, forex e índices usan precios simulados como fallback.
FINNHUB_API_KEY=TU_FINNHUB_API_KEY

# --- Metals API (Oro y Plata en tiempo real) ---
# Plan gratuito en https://metals-api.com/register (100 llamadas/mes)
# Sin esta clave, oro y plata usan precios simulados como fallback.
METALS_API_KEY=TU_METALS_API_KEY
