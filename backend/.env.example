# ===========================================================
# TradingCalculator.pro — Backend Environment Variables
# Copy this file to .env and fill in all values
# ===========================================================

# ---- DATABASE -----------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_calculator_pro

# ---- SECURITY (REQUIRED in production) ----------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ⚠️  Without this the server will REFUSE to start in production
JWT_SECRET=

# ---- DEMO USER ----------------------------------------------
DEMO_EMAIL=demo@btccalc.pro
DEMO_PASSWORD=1234
# Set true only for local/demo environments. Production default is disabled.
ENABLE_DEMO_USER=false

# ---- GOOGLE OAUTH -------------------------------------------
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=

# ---- STRIPE (payments) --------------------------------------
# Use sk_test_... for dev / sk_live_... for production
STRIPE_API_KEY=sk_test_emergent
STRIPE_WEBHOOK_SECRET=

# ---- SENDGRID (email alerts) --------------------------------
SENDGRID_API_KEY=
SENDER_EMAIL=alerts@tradingcalculator.pro

# ---- EMERGENT LLM (AI Trade Coach — Claude) -----------------
EMERGENT_LLM_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- FINNHUB (real-time Forex & Indices) --------------------
# Free key at https://finnhub.io — 60 req/min on free tier
# Without this, Forex & Indices will use static fallback data
FINNHUB_API_KEY=

# ---- CORS ---------------------------------------------------
CORS_ORIGINS=*
